    \href{<< pub.url >>}{[PDF]}<<% if pub.codeUrl is defined and pub.codeUrl %>> \href{<< pub.codeUrl >>}{[Code]}<<% endif %>><<% if pub.demoUrl is defined and pub.demoUrl %>> \href{<< pub.demoUrl >>}{[Demo]}<<% endif %>>
<<% endfor %>>
