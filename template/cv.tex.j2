% Section formatting
\titleformat{\section}
  {\vspace{-4pt}\scshape\raggedright\large\bfseries}
  {}{0em}{}[\color{black}\titlerule\vspace{-5pt}]

% Custom commands
\newcommand{\cvItem}[1]{
  \item\small{#1 \vspace{-2pt}}
}

\newcommand{\cvEntry}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & \small #3 \\
      \textit{\small#2} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\cvProjectHeading}[2]{
  \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & \small #2 \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\cvListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\cvListEnd}{\end{itemize}}
\newcommand{\cvItemListStart}{\begin{itemize}[itemsep=-2pt]}
\newcommand{\cvItemListEnd}{\end{itemize}\vspace{-5pt}}

