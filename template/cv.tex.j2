%-----------EDUCATION-----------
\section{Education}
\cvListStart
<<% for edu in education %>>
  \cvEntry
    {\href{<< edu.url >>}{<< edu.institution | latex >>}}
    {<< edu.studyType | latex >>}
    {<< edu.score | latex >>}
    {<< edu.startDate | format_date >> -- << edu.endDate | format_date >>}
    \cvItemListStart
<<% for h in edu.highlights %>>
      \cvItem{<< h | latex >>}
<<% endfor %>>
    \cvItemListEnd
<<% endfor %>>
\cvListEnd

%-----------EXPERIENCE-----------
\section{Experience}
\cvListStart
<<% for job in work %>>
  \cvEntry
    {<< job.name | latex >><<% if job.note is defined and job.note %>> {\footnotesize (<< job.note | latex >>)}<<% endif %>>}
    {<< job.position | latex >>}
    {<< job.location | latex >>}
    {<< job.startDate | format_date >> -- << job.endDate | format_date >>}
    \cvItemListStart
<<% for h in job.highlights %>>
      \cvItem{<< h | latex >>}
<<% endfor %>>
    \cvItemListEnd
<<% endfor %>>
\cvListEnd

